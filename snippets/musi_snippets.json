{
	"Let Binding": {
		"prefix": "let",
		"body": [
			"let ${1:name} := ${0:value};"
		],
		"description": "Value binding"
	},
	"Let-Rec Callable": {
		"prefix": "letrec",
		"body": [
			"let rec ${1:name}(${2:x}: ${3:Int}) : ${4:Int} := ${0:body};"
		],
		"description": "Recursive callable binding"
	},
	"Lambda Expression": {
		"prefix": "lambda",
		"body": [
			"\\(${1:x}) => ${0:body}"
		],
		"description": "Lambda expression"
	},
	"Data Declaration": {
		"prefix": "data",
		"body": [
			"let ${1:Type} := data {",
			"\t| ${2:Variant}(${3:value}: ${4:Type})",
			"};"
		],
		"description": "Data declaration"
	},
	"Effect Declaration": {
		"prefix": "effect",
		"body": [
			"let ${1:Effect} := effect {",
			"\tlet ${2:op}(${3:payload}: ${4:Type}) : ${5:Type};",
			"\tlaw ${6:name}(${7:x}: ${8:Type}) := ${0:body};",
			"};"
		],
		"description": "Effect declaration with operation and law"
	},
	"Handle Expression": {
		"prefix": "handle",
		"body": [
			"let ${1:answerName} := answer ${2:Effect} {",
			"\tlet ${3:op}(${4:value}: ${5:Type}) := ${6:resume ${4:value};}",
			"};",
			"handle (${7:work;}) answer ${1:answerName};"
		],
		"description": "Answer value plus handle expression"
	},
	"Quote Expression": {
		"prefix": "quote",
		"body": [
			"quote (${0:expr})"
		],
		"description": "Quoted expression syntax"
	},
	"Quote Module": {
		"prefix": "quotemod",
		"body": [
			"quote {",
			"\t${0:let value := 1;}",
			"}"
		],
		"description": "Quoted module syntax"
	},
	"Comptime Expression": {
		"prefix": "comptime",
		"body": [
			"comptime ${0:expr}"
		],
		"description": "Compile-time expression"
	},
	"Comptime Parameter": {
		"prefix": "comptimeparam",
		"body": [
			"let ${1:name}(comptime ${2:n}: ${3:Int}, ${4:x}: ${5:Int}) : ${6:Int} := ${0:body};"
		],
		"description": "Callable with a compile-time parameter"
	},
	"Comptime Quote Module": {
		"prefix": "comptimequote",
		"body": [
			"comptime quote {",
			"\t${0:export let value () : Int := 1;}",
			"};"
		],
		"description": "Compile-time quoted module expansion"
	},
	"Comptime-Safe Effect Operation": {
		"prefix": "comptimesafe",
		"body": [
			"@comptimeSafe",
			"let ${1:op}(${2:value}: ${3:Type}) : ${0:Type};"
		],
		"description": "Effect operation allowed for compile-time host handling"
	},
	"Native Let Binding": {
		"prefix": "native",
		"body": [
			"native ${1:\"c\"} let ${2:name}(${3:x}: ${4:Int}) : ${5:Int};"
		],
		"description": "Native let binding"
	},
	"Shape Declaration": {
		"prefix": "shape",
		"body": [
			"let ${1:Shape}[${2:T}] := shape {",
			"\tlaw ${3:name}(${4:value}: ${2:T}) := ${0:body};",
			"};"
		],
		"description": "Shape declaration with law"
	},
	"Given Declaration": {
		"prefix": "given",
		"body": [
			"let ${1:provider} := given ${2:Shape}[${3:Type}] {",
			"\tlaw ${4:name}(${5:value}: ${3:Type}) := ${0:body};",
			"};"
		],
		"description": "Contextual given provider"
	},
	"Ask Expression": {
		"prefix": "ask",
		"body": [
			"ask ${1:Effect}.${2:op}(${0:value})"
		],
		"description": "Effect ask expression"
	},
	"Pin Action": {
		"prefix": "pin",
		"body": [
			"pin ${1:value} as ${2:pinned} in ${0:body}"
		],
		"description": "Pin action form"
	},
	"Match Expression": {
		"prefix": "match",
		"body": [
			"match ${1:expr} (",
			"\t| ${2:pattern} => ${0:result}",
			")"
		],
		"description": "Match expression"
	}
}
