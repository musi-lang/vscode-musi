{
	"comments": {
		"lineComment": {
			"comment": "--"
		},
		"blockComment": ["/-", "-/"]
	},
	"brackets": [["{", "}"], ["[", "]"], ["(", ")"]],
	"autoClosingPairs": [
		{
			"open": "{",
			"close": "}"
		},
		{
			"open": "[",
			"close": "]"
		},
		{
			"open": "(",
			"close": ")"
		},
		{
			"open": "\"",
			"close": "\"",
			"notIn": ["string"]
		},
		{
			"open": "'",
			"close": "'",
			"notIn": ["string"]
		},
		{
			"open": "`",
			"close": "`",
			"notIn": ["string", "comment"]
		}
	],
	"surroundingPairs": [
		{
			"open": "{",
			"close": "}"
		},
		{
			"open": "[",
			"close": "]"
		},
		{
			"open": "(",
			"close": ")"
		},
		{
			"open": "\"",
			"close": "\""
		},
		{
			"open": "'",
			"close": "'"
		},
		{
			"open": "`",
			"close": "`"
		}
	],
	"wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
	"folding": {
		"markers": {
			"start": "^\\s*\\{\\s*$",
			"end": "^\\s*\\}\\s*$"
		}
	}
}
